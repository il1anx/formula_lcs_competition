PBK_START_MY_BRAKE(2,1) 0 ; MPa ! [D] Subtracted from wheel cylinder pressure
PBK_SCALE_MY_BRAKE(2,1) 1 ! [D] Divided into (wheel cylinder pressure -
                          ! PBK_START_MY_BRAKE)

! Col 1 = wheel cylinder pressure (MPa), col 2 = brake torque (N-m)
MY_BRAKE_TABLE(2,2) SPLINE ! axle 2, right side
 0, 0
