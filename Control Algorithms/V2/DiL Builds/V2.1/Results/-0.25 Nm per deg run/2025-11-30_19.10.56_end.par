ENDTABLE
CAMBER_GAIN(2,1)    1 ! [D] Multiplied with calculated value to get camber
CAMBER_OFFSET(2,1)  0 ; deg ! [D] Added (after gain) to get camber
JNC_START_CAMBER(2,1) 0 ; mm ! [D] Subtracted from jounce
JNC_SCALE_CAMBER(2,1) 1 ! [D] Divided into (jounce - JNC_START_CAMBER)
CAMBER_COMBINE(2,1) ADD ! How to combine the two components
SET_UNITS SUSP_CAMBER_JNC_OTHER_SIDE_TABLE(2,1) deg ;
SUSP_CAMBER_JNC_OTHER_SIDE_CONSTANT(2,1) 0 ; deg ! Camber component due to jounce
                                           ! (other side), axle 2, left side

! Col 1 = jounce (mm), col 2 = camber (deg)
CAMBER_TABLE(2,2) SPLINE ! axle 2, right side
 -16, 0.54422
