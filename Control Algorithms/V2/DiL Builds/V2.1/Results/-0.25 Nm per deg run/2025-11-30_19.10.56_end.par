                             ! (mm/mm), axle 1, left side
CMP_JSTOP_GAIN(1,1) 1 ! [D] Multiplied with calculated value to get jounce stop
                      ! deflection
CMP_JSTOP_OFFSET(1,1) 0 ; mm ! [D] Added (after gain) to get jounce stop deflection
JNC_START_CMP_JSTOP(1,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_JSTOP(1,1) 1 ! [D] Divided into (jounce at wheel -
                           ! JNC_START_CMP_JSTOP)

