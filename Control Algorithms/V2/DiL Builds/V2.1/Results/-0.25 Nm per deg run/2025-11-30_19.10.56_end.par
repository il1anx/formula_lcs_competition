 16, -0.93603
 18, -1.03206
 20, -1.12884
 22, -1.22638
 24, -1.32469
 26, -1.42378
 28, -1.52366
 30, -1.62433
 32, -1.72581
 34, -1.8281
 36, -1.93121
 38, -2.03515
 40, -2.13993
ENDTABLE
CAMBER_GAIN(1,2)    1 ! [D] Multiplied with calculated value to get camber
CAMBER_OFFSET(1,2)  0 ; deg ! [D] Added (after gain) to get camber
JNC_START_CAMBER(1,2) 0 ; mm ! [D] Subtracted from jounce
JNC_SCALE_CAMBER(1,2) 1 ! [D] Divided into (jounce - JNC_START_CAMBER)
CAMBER_COMBINE(1,2) ADD ! How to combine the two components
SET_UNITS SUSP_CAMBER_JNC_OTHER_SIDE_TABLE(1,2) deg ;
SUSP_CAMBER_JNC_OTHER_SIDE_CONSTANT(1,2) 0 ; deg ! Camber component due to jounce
                                           ! (other side), axle 1, right side

! Col 1 = jounce (mm), col 2 = camber (deg)
CAMBER_TABLE(2,1) SPLINE ! axle 2, left side
 -16, 0.54422
