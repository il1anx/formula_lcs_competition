! CMP_SPR_SEAT: Lower spring seat movement. Lower spring seat movement can be a
! nonlinear CARPET function of jounce at wheel (other side) and jounce at wheel or a
! function of jounce at wheel (COEFFICIENT or TABLE). Lower spring seat movement from
! the calculation can be adjusted with CMP_SPR_SEAT_GAIN and CMP_SPR_SEAT_OFFSET.
! Jounce at wheel used in the calculation can be adjusted with JNC_SCALE_CMP_SPR_SEAT
! and JNC_START_CMP_SPR_SEAT. Jounce at wheel (other side) used in the calculation
! can be adjusted with JNC2_SCALE_CMP_SPR_SEAT and JNC2_START_CMP_SPR_SEAT. An
! inverse version of this function is used internally. The derivative of this
! function is used internally. This configurable function supports 4 datasets; if
! indices shown below are not used, e.g., (1,2), the current values of the indices
! IAXLE and ISIDE are used to identify the dataset when reading data.

CMP_SPR_SEAT_COEFFICIENT(1,1) 1 ! [D] Lower spring seat movement per unit jounce at
                                ! wheel (mm/mm), axle 1, left side
CMP_SPR_SEAT_GAIN(1,1) 1 ! [D] Multiplied with calculated value to get lower spring
                         ! seat movement
CMP_SPR_SEAT_OFFSET(1,1) 0 ; mm ! [D] Added (after gain) to get lower spring seat
                           ! movement
JNC_START_CMP_SPR_SEAT(1,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_SPR_SEAT(1,1) 1 ! [D] Divided into (jounce at wheel -
                              ! JNC_START_CMP_SPR_SEAT)

CMP_SPR_SEAT_COEFFICIENT(1,2) 1 ! [D] Lower spring seat movement per unit jounce at
                                ! wheel (mm/mm), axle 1, right side
CMP_SPR_SEAT_GAIN(1,2) 1 ! [D] Multiplied with calculated value to get lower spring
                         ! seat movement
CMP_SPR_SEAT_OFFSET(1,2) 0 ; mm ! [D] Added (after gain) to get lower spring seat
                           ! movement
JNC_START_CMP_SPR_SEAT(1,2) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_SPR_SEAT(1,2) 1 ! [D] Divided into (jounce at wheel -
                              ! JNC_START_CMP_SPR_SEAT)

CMP_SPR_SEAT_COEFFICIENT(2,1) 1 ! [D] Lower spring seat movement per unit jounce at
                                ! wheel (mm/mm), axle 2, left side
CMP_SPR_SEAT_GAIN(2,1) 1 ! [D] Multiplied with calculated value to get lower spring
                         ! seat movement
CMP_SPR_SEAT_OFFSET(2,1) 0 ; mm ! [D] Added (after gain) to get lower spring seat
                           ! movement
JNC_START_CMP_SPR_SEAT(2,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_SPR_SEAT(2,1) 1 ! [D] Divided into (jounce at wheel -
                              ! JNC_START_CMP_SPR_SEAT)

CMP_SPR_SEAT_COEFFICIENT(2,2) 1 ! [D] Lower spring seat movement per unit jounce at
                                ! wheel (mm/mm), axle 2, right side
CMP_SPR_SEAT_GAIN(2,2) 1 ! [D] Multiplied with calculated value to get lower spring
                         ! seat movement
CMP_SPR_SEAT_OFFSET(2,2) 0 ; mm ! [D] Added (after gain) to get lower spring seat
                           ! movement
JNC_START_CMP_SPR_SEAT(2,2) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_SPR_SEAT(2,2) 1 ! [D] Divided into (jounce at wheel -
                              ! JNC_START_CMP_SPR_SEAT)

! CS_FY: Compliance: steer due to in- and out-phase Fy. Steer displacement can be a
! nonlinear CARPET function of force (other side) and force or a function of force
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Steer displacement from the calculation can be adjusted with CS_FY_GAIN
! and CS_FY_OFFSET. Force used in the calculation can be adjusted with F_SCALE_CS_FY
! and F_START_CS_FY. Force (other side) used in the calculation can be adjusted with
! F2_SCALE_CS_FY and F2_START_CS_FY. This configurable function supports 4 datasets;
! if indices shown below are not used, e.g., (1,2), the current values of the indices
! IAXLE and ISIDE are used to identify the dataset when reading data.

CS_FY_COEFFICIENT(1,1) 0 ! Steer displacement per unit force (deg/N), axle 1, left
                         ! side
CS_FY_OFFSET(1,1)   0 ; deg ! [D] Added (after gain) to get Steer displacement
F_START_CS_FY(1,1)  0 ; N ! [D] Subtracted from force
F_SCALE_CS_FY(1,1)  1 ! [D] Divided into (force - F_START_CS_FY)

CS_FY_COEFFICIENT(1,2) 0 ! Steer displacement per unit force (deg/N), axle 1, right
                         ! side
CS_FY_OFFSET(1,2)   0 ; deg ! [D] Added (after gain) to get Steer displacement
F_START_CS_FY(1,2)  0 ; N ! [D] Subtracted from force
F_SCALE_CS_FY(1,2)  1 ! [D] Divided into (force - F_START_CS_FY)

CS_FY_COEFFICIENT(2,1) 0 ! Steer displacement per unit force (deg/N), axle 2, left
                         ! side
CS_FY_OFFSET(2,1)   0 ; deg ! [D] Added (after gain) to get Steer displacement
F_START_CS_FY(2,1)  0 ; N ! [D] Subtracted from force
F_SCALE_CS_FY(2,1)  1 ! [D] Divided into (force - F_START_CS_FY)

CS_FY_COEFFICIENT(2,2) 0 ! Steer displacement per unit force (deg/N), axle 2, right
                         ! side
CS_FY_OFFSET(2,2)   0 ; deg ! [D] Added (after gain) to get Steer displacement
F_START_CS_FY(2,2)  0 ; N ! [D] Subtracted from force
F_SCALE_CS_FY(2,2)  1 ! [D] Divided into (force - F_START_CS_FY)

! CS_MZ: Compliance: steer due to in- and out-phase Mz. Steer displacement can be a
! nonlinear CARPET function of moment and moment or a function of moment (CONSTANT,
! COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined at runtime.
! Steer displacement from the calculation can be adjusted with CS_MZ_GAIN and
! CS_MZ_OFFSET. Moment used in the calculation can be adjusted with M_SCALE_CS_MZ and
! M_START_CS_MZ. Moment used in the calculation can be adjusted with M2_SCALE_CS_MZ
! and M2_START_CS_MZ. This configurable function supports 4 datasets; if indices
! shown below are not used, e.g., (1,2), the current values of the indices IAXLE and
! ISIDE are used to identify the dataset when reading data.

CS_MZ_COEFFICIENT(1,1) 0 ! Steer displacement per unit moment (deg/N-m), axle 1,
                         ! left side
CS_MZ_OFFSET(1,1)   0 ; deg ! [D] Added (after gain) to get steer displacement
M_START_CS_MZ(1,1)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CS_MZ(1,1)  1 ! [D] Divided into (moment - M_START_CS_MZ)

CS_MZ_COEFFICIENT(1,2) 0 ! Steer displacement per unit moment (deg/N-m), axle 1,
                         ! right side
CS_MZ_OFFSET(1,2)   0 ; deg ! [D] Added (after gain) to get steer displacement
M_START_CS_MZ(1,2)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CS_MZ(1,2)  1 ! [D] Divided into (moment - M_START_CS_MZ)

CS_MZ_COEFFICIENT(2,1) 0 ! Steer displacement per unit moment (deg/N-m), axle 2,
                         ! left side
CS_MZ_OFFSET(2,1)   0 ; deg ! [D] Added (after gain) to get steer displacement
M_START_CS_MZ(2,1)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CS_MZ(2,1)  1 ! [D] Divided into (moment - M_START_CS_MZ)

CS_MZ_COEFFICIENT(2,2) 0 ! Steer displacement per unit moment (deg/N-m), axle 2,
                         ! right side
CS_MZ_OFFSET(2,2)   0 ; deg ! [D] Added (after gain) to get steer displacement
M_START_CS_MZ(2,2)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CS_MZ(2,2)  1 ! [D] Divided into (moment - M_START_CS_MZ)

! CT_FX: Compliance: wheel toe due to in- and out-phase Fx. Toe displacement can be
! a nonlinear CARPET function of force (other side) and force or a function of force
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Toe displacement from the calculation can be adjusted with CT_FX_GAIN
! and CT_FX_OFFSET. Force used in the calculation can be adjusted with F_SCALE_CT_FX
! and F_START_CT_FX. Force (other side) used in the calculation can be adjusted with
! F2_SCALE_CT_FX and F2_START_CT_FX. This configurable function supports 4 datasets;
! if indices shown below are not used, e.g., (1,2), the current values of the indices
! IAXLE and ISIDE are used to identify the dataset when reading data.

CT_FX_COEFFICIENT(1,1) 0 ! Toe displacement per unit force (deg/N), axle 1, left
                         ! side
CT_FX_OFFSET(1,1)   0 ; deg ! [D] Added (after gain) to get toe displacement
F_START_CT_FX(1,1)  0 ; N ! [D] Subtracted from force
F_SCALE_CT_FX(1,1)  1 ! [D] Divided into (force - F_START_CT_FX)

CT_FX_COEFFICIENT(1,2) 0 ! Toe displacement per unit force (deg/N), axle 1, right
                         ! side
CT_FX_OFFSET(1,2)   0 ; deg ! [D] Added (after gain) to get toe displacement
F_START_CT_FX(1,2)  0 ; N ! [D] Subtracted from force
F_SCALE_CT_FX(1,2)  1 ! [D] Divided into (force - F_START_CT_FX)

CT_FX_COEFFICIENT(2,1) 0 ! Toe displacement per unit force (deg/N), axle 2, left
                         ! side
CT_FX_OFFSET(2,1)   0 ; deg ! [D] Added (after gain) to get toe displacement
F_START_CT_FX(2,1)  0 ; N ! [D] Subtracted from force
F_SCALE_CT_FX(2,1)  1 ! [D] Divided into (force - F_START_CT_FX)

CT_FX_COEFFICIENT(2,2) 0 ! Toe displacement per unit force (deg/N), axle 2, right
                         ! side
CT_FX_OFFSET(2,2)   0 ; deg ! [D] Added (after gain) to get toe displacement
F_START_CT_FX(2,2)  0 ; N ! [D] Subtracted from force
F_SCALE_CT_FX(2,2)  1 ! [D] Divided into (force - F_START_CT_FX)

! C_LAT: Compliance: lateral displacement of wheel due to in- and out-phase Fy .
! Lateral displacement can be a nonlinear CARPET function of force (other side) and
! force or a function of force (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a
! custom equation can be defined at runtime. Lateral displacement from the
! calculation can be adjusted with C_LAT_GAIN and C_LAT_OFFSET. Force used in the
! calculation can be adjusted with F_SCALE_C_LAT and F_START_C_LAT. Force (other
! side) used in the calculation can be adjusted with F2_SCALE_C_LAT and
! F2_START_C_LAT. This configurable function supports 4 datasets; if indices shown
! below are not used, e.g., (1,2), the current values of the indices IAXLE and ISIDE
! are used to identify the dataset when reading data.

C_LAT_COEFFICIENT(1,1) 0 ! Lateral displacement per unit force (mm/N), axle 1, left
                         ! side
C_LAT_OFFSET(1,1)   0 ; mm ! [D] Added (after gain) to get lateral displacement
F_START_C_LAT(1,1)  0 ; N ! [D] Subtracted from force
F_SCALE_C_LAT(1,1)  1 ! [D] Divided into (force - F_START_C_LAT)

C_LAT_COEFFICIENT(1,2) 0 ! Lateral displacement per unit force (mm/N), axle 1, right
                         ! side
C_LAT_OFFSET(1,2)   0 ; mm ! [D] Added (after gain) to get lateral displacement
F_START_C_LAT(1,2)  0 ; N ! [D] Subtracted from force
F_SCALE_C_LAT(1,2)  1 ! [D] Divided into (force - F_START_C_LAT)

C_LAT_COEFFICIENT(2,1) 0 ! Lateral displacement per unit force (mm/N), axle 2, left
                         ! side
C_LAT_OFFSET(2,1)   0 ; mm ! [D] Added (after gain) to get lateral displacement
F_START_C_LAT(2,1)  0 ; N ! [D] Subtracted from force
F_SCALE_C_LAT(2,1)  1 ! [D] Divided into (force - F_START_C_LAT)

C_LAT_COEFFICIENT(2,2) 0 ! Lateral displacement per unit force (mm/N), axle 2, right
                         ! side
C_LAT_OFFSET(2,2)   0 ; mm ! [D] Added (after gain) to get lateral displacement
F_START_C_LAT(2,2)  0 ; N ! [D] Subtracted from force
F_SCALE_C_LAT(2,2)  1 ! [D] Divided into (force - F_START_C_LAT)

! C_LONG: Compliance: wheel longitudinal displacement due to in- and out-phase Fx. X
! displacement can be a nonlinear CARPET function of force (other side) and force or
! a function of force (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom
! equation can be defined at runtime. X displacement from the calculation can be
! adjusted with C_LONG_GAIN and C_LONG_OFFSET. Force used in the calculation can be
! adjusted with F_SCALE_C_LONG and F_START_C_LONG. Force (other side) used in the
! calculation can be adjusted with F2_SCALE_C_LONG and F2_START_C_LONG. This
! configurable function supports 4 datasets; if indices shown below are not used,
! e.g., (1,2), the current values of the indices IAXLE and ISIDE are used to identify
! the dataset when reading data.

C_LONG_COEFFICIENT(1,1) 0 ! X displacement per unit force (mm/N), axle 1, left side
C_LONG_OFFSET(1,1)  0 ; mm ! [D] Added (after gain) to get X displacement
F_START_C_LONG(1,1) 0 ; N ! [D] Subtracted from force
F_SCALE_C_LONG(1,1) 1 ! [D] Divided into (force - F_START_C_LONG)

C_LONG_COEFFICIENT(1,2) 0 ! X displacement per unit force (mm/N), axle 1, right side
C_LONG_OFFSET(1,2)  0 ; mm ! [D] Added (after gain) to get X displacement
F_START_C_LONG(1,2) 0 ; N ! [D] Subtracted from force
F_SCALE_C_LONG(1,2) 1 ! [D] Divided into (force - F_START_C_LONG)

C_LONG_COEFFICIENT(2,1) 0 ! X displacement per unit force (mm/N), axle 2, left side
C_LONG_OFFSET(2,1)  0 ; mm ! [D] Added (after gain) to get X displacement
F_START_C_LONG(2,1) 0 ; N ! [D] Subtracted from force
F_SCALE_C_LONG(2,1) 1 ! [D] Divided into (force - F_START_C_LONG)

C_LONG_COEFFICIENT(2,2) 0 ! X displacement per unit force (mm/N), axle 2, right side
C_LONG_OFFSET(2,2)  0 ; mm ! [D] Added (after gain) to get X displacement
F_START_C_LONG(2,2) 0 ; N ! [D] Subtracted from force
F_SCALE_C_LONG(2,2) 1 ! [D] Divided into (force - F_START_C_LONG)

! FD: Suspension damper force (1 side). Damper force is a function of compression
! speed (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be
! defined at runtime. Damper force from the calculation can be adjusted with FD_GAIN
! and FD_OFFSET. Compression speed used in the calculation can be adjusted with
! CMP_R_SCALE_FD and CMP_R_START_FD. This configurable function supports 4 datasets;
! if indices shown below are not used, e.g., (1,2), the current values of the indices
! IAXLE and ISIDE are used to identify the dataset when reading data.

