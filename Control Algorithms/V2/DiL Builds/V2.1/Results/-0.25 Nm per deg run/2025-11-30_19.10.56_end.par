! FZA_UL(1) 1347.607821 ; N ! CALC -- Static ground load, unladen, axle 1
! FZ_STATIC(1,1) 673.8039105 ; N ! CALC -- Static ground force, laden, wheel L1
! FZ_STATIC(1,2) 673.8039105 ; N ! CALC -- Static ground force, laden, wheel R1
! KA_ROLL(1) 495.1150022 ; N-m/deg ! CALC -- Total roll stiffness, axle 1
L_SPG_ADJ(1,1)      0 ; mm ! [D] Upper seat height increase for spring L1 to reduce
