MMOTOR_MAX_OFFSET(2,1) 0 ; N-m ! [D] Added (after gain) to get Motor full torque
SPIN_START_M_MOTOR_MAX(2,1) 0 ; rpm ! [D] Subtracted from motor speed
SPIN_SCALE_M_MOTOR_MAX(2,1) 0.07272727273 ! Divided into (motor speed -
                                          ! SPIN_START_M_MOTOR_MAX)

