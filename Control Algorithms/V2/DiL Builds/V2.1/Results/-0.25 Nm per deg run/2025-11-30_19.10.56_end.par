! FSA_L(1) 1217.259725 ; N ! CALC -- Static suspension load, laden, axle  1
FS_OFFSET(1,1)      0 ; N ! Force offset subtracted from built-in spring L1 [I]
FS_OFFSET(1,2)      0 ; N ! Force offset subtracted from built-in spring R1 [I]
! FS_STATIC(1,1) 608.6298626 ; N ! CALC -- Static spring force, laden, spring L1
! FS_STATIC(1,2) 608.6298626 ; N ! CALC -- Static spring force, laden, spring R1
