JNC_START_CMP_JSTOP(2,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_JSTOP(2,1) 1 ! [D] Divided into (jounce at wheel -
                           ! JNC_START_CMP_JSTOP)

CMP_JSTOP_COEFFICIENT(2,2) 1 ! [D] Jounce stop deflection per unit jounce at wheel
                             ! (mm/mm), axle 2, right side
CMP_JSTOP_GAIN(2,2) 1 ! [D] Multiplied with calculated value to get jounce stop
