CI_MZ_COEFFICIENT(1,1) 0 ! Inclination displacement per unit moment (deg/N-m), axle
                         ! 1, left side
CI_MZ_OFFSET(1,1)   0 ; deg ! [D] Added (after gain) to get inclination displacement
M_START_CI_MZ(1,1)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CI_MZ(1,1)  1 ! [D] Divided into (moment - M_START_CI_MZ)

CI_MZ_COEFFICIENT(1,2) 0 ! Inclination displacement per unit moment (deg/N-m), axle
                         ! 1, right side
CI_MZ_OFFSET(1,2)   0 ; deg ! [D] Added (after gain) to get inclination displacement
M_START_CI_MZ(1,2)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CI_MZ(1,2)  1 ! [D] Divided into (moment - M_START_CI_MZ)

CI_MZ_COEFFICIENT(2,1) 0 ! Inclination displacement per unit moment (deg/N-m), axle
                         ! 2, left side
CI_MZ_OFFSET(2,1)   0 ; deg ! [D] Added (after gain) to get inclination displacement
M_START_CI_MZ(2,1)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CI_MZ(2,1)  1 ! [D] Divided into (moment - M_START_CI_MZ)

CI_MZ_COEFFICIENT(2,2) 0 ! Inclination displacement per unit moment (deg/N-m), axle
                         ! 2, right side
CI_MZ_OFFSET(2,2)   0 ; deg ! [D] Added (after gain) to get inclination displacement
M_START_CI_MZ(2,2)  0 ; N-m ! [D] Subtracted from moment
M_SCALE_CI_MZ(2,2)  1 ! [D] Divided into (moment - M_START_CI_MZ)

! CLUTCH_CONTROL_DIFF: Differential clutch control input based on total torque
! applied to both output shafts. Normalized clutch input is a function of torque
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Normalized clutch input from the calculation can be adjusted with
! CLUTCH_CONTROL_DIFF_GAIN and CLUTCH_CONTROL_DIFF_OFFSET. Torque used in the
! calculation can be adjusted with M_SCALE_CL_CON_DIFF and M_START_CL_CON_DIFF. This
! configurable function supports 3 datasets; if indices shown below are not used,
! e.g., (2), the current value of the index IDIFF is used to identify the dataset
! when reading data.

CLUTCH_CONTROL_DIFF_CONSTANT(2) 1 ; - ! [D] Normalized clutch input, rear diff
CLUTCH_CONTROL_DIFF_GAIN(2) 1 ! [D] Multiplied with calculated value to get
                              ! normalized clutch input
CLUTCH_CONTROL_DIFF_OFFSET(2) 0 ; - ! [D] Added to get normalized clutch input

! CLUTCH_TORQUE_DIFF: Available torque for differential clutch. Available torque is
! a function of normalized clutch input (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. Available torque from
! the calculation can be adjusted with CLUTCH_TORQUE_DIFF_GAIN and
! CLUTCH_TORQUE_DIFF_OFFSET. Normalized clutch input used in the calculation can be
! adjusted with CON_SCALE_CL_TORQ_DIFF and CON_START_CL_TORQ_DIFF. This configurable
! function supports 3 datasets; if indices shown below are not used, e.g., (2), the
! current value of the index IDIFF is used to identify the dataset when reading data.

CLUTCH_TORQUE_DIFF_CONSTANT(2) 0 ; N-m ! [D] Available torque, rear diff
CLUTCH_TORQUE_DIFF_OFFSET(2) 0 ; N-m ! [D] Added to get available torque

! CMP_DAMP: Damper compression. Damper compression can be a nonlinear CARPET
! function of jounce at wheel (other side) and jounce at wheel or a function of
! jounce at wheel (CONSTANT, COEFFICIENT, or TABLE). Damper compression from the
! calculation can be adjusted with CMP_DAMP_GAIN and CMP_DAMP_OFFSET. Jounce at wheel
! used in the calculation can be adjusted with JNC_SCALE_CMP_DAMP and
! JNC_START_CMP_DAMP. Jounce at wheel (other side) used in the calculation can be
! adjusted with JNC2_SCALE_CMP_DAMP and JNC2_START_CMP_DAMP. The derivative of this
! function is used internally. This configurable function supports 4 datasets; if
! indices shown below are not used, e.g., (1,2), the current values of the indices
! IAXLE and ISIDE are used to identify the dataset when reading data.

CMP_DAMP_COEFFICIENT(1,1) 1 ! [D] Damper compression per unit jounce at wheel
                            ! (mm/mm), axle 1, left side
CMP_DAMP_GAIN(1,1)  1 ! [D] Multiplied with calculated value to get damper
                      ! compression
CMP_DAMP_OFFSET(1,1) 0 ; mm ! [D] Added (after gain) to get damper compression
JNC_START_CMP_DAMP(1,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_DAMP(1,1) 1 ! [D] Divided into (jounce at wheel - JNC_START_CMP_DAMP)

CMP_DAMP_COEFFICIENT(1,2) 1 ! [D] Damper compression per unit jounce at wheel
                            ! (mm/mm), axle 1, right side
CMP_DAMP_GAIN(1,2)  1 ! [D] Multiplied with calculated value to get damper
                      ! compression
CMP_DAMP_OFFSET(1,2) 0 ; mm ! [D] Added (after gain) to get damper compression
JNC_START_CMP_DAMP(1,2) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_DAMP(1,2) 1 ! [D] Divided into (jounce at wheel - JNC_START_CMP_DAMP)

CMP_DAMP_COEFFICIENT(2,1) 1 ! [D] Damper compression per unit jounce at wheel
                            ! (mm/mm), axle 2, left side
CMP_DAMP_GAIN(2,1)  1 ! [D] Multiplied with calculated value to get damper
                      ! compression
CMP_DAMP_OFFSET(2,1) 0 ; mm ! [D] Added (after gain) to get damper compression
JNC_START_CMP_DAMP(2,1) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_DAMP(2,1) 1 ! [D] Divided into (jounce at wheel - JNC_START_CMP_DAMP)

CMP_DAMP_COEFFICIENT(2,2) 1 ! [D] Damper compression per unit jounce at wheel
                            ! (mm/mm), axle 2, right side
CMP_DAMP_GAIN(2,2)  1 ! [D] Multiplied with calculated value to get damper
                      ! compression
CMP_DAMP_OFFSET(2,2) 0 ; mm ! [D] Added (after gain) to get damper compression
JNC_START_CMP_DAMP(2,2) 0 ; mm ! [D] Subtracted from jounce at wheel
JNC_SCALE_CMP_DAMP(2,2) 1 ! [D] Divided into (jounce at wheel - JNC_START_CMP_DAMP)

! CMP_JSTOP: Jounce bumper deflection. Jounce stop deflection can be a nonlinear
! CARPET function of jounce at wheel (other side) and jounce at wheel or a function
! of jounce at wheel (CONSTANT, COEFFICIENT, or TABLE). Jounce stop deflection from
! the calculation can be adjusted with CMP_JSTOP_GAIN and CMP_JSTOP_OFFSET. Jounce at
! wheel used in the calculation can be adjusted with JNC_SCALE_CMP_JSTOP and
