! FS_COMP: Compression (upper) envelope of suspension spring force (1 side). Spring
! force can be a nonlinear CARPET function of static spring force and spring
! compression or a function of spring compression (CONSTANT, COEFFICIENT, or TABLE)
! combined with a function FS_COMP_FSTATIC of static spring force (CONSTANT,
! COEFFICIENT, or TABLE). Spring force from the calculation can be adjusted with
! FS_COMP_GAIN and FS_COMP_OFFSET. Spring compression used in the calculation can be
! adjusted with CMP_SCALE_FS_COMP and CMP_START_FS_COMP. Static spring force used in
! the calculation can be adjusted with FSTATIC_SCALE_FS_COMP and
! FSTATIC_START_FS_COMP. An inverse version of this function is used internally. This
! configurable function supports 4 datasets; if indices shown below are not used,
! e.g., (1,2), the current values of the indices IAXLE and ISIDE are used to identify
! the dataset when reading data.

FS_COMP_COEFFICIENT(1,1) 39.4 ! Spring force per unit spring compression (N/mm),
                              ! axle 1, left side
FS_COMP_GAIN(1,1)   1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(1,1) 10 ; N ! Added (after gain) to get spring force
CMP_START_FS_COMP(1,1) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_COMP(1,1) 1 ! [D] Divided into (spring compression - CMP_START_FS_COMP)
FS_COMP_COMBINE(1,1) MULTIPLY ! [D] How to combine the two components
FS_COMP_FSTATIC_CONSTANT(1,1) 1 ; - ! [D] Spring force component due to static
                                ! spring force, axle 1, left side

FS_COMP_COEFFICIENT(1,2) 39.4 ! Spring force per unit spring compression (N/mm),
                              ! axle 1, right side
FS_COMP_GAIN(1,2)   1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(1,2) 10 ; N ! Added (after gain) to get spring force
CMP_START_FS_COMP(1,2) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_COMP(1,2) 1 ! [D] Divided into (spring compression - CMP_START_FS_COMP)
FS_COMP_COMBINE(1,2) MULTIPLY ! [D] How to combine the two components
FS_COMP_FSTATIC_CONSTANT(1,2) 1 ; - ! [D] Spring force component due to static
                                ! spring force, axle 1, right side

FS_COMP_COEFFICIENT(2,1) 43.781 ! Spring force per unit spring compression (N/mm),
                                ! axle 2, left side
FS_COMP_GAIN(2,1)   1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(2,1) 10 ; N ! Added (after gain) to get spring force
CMP_START_FS_COMP(2,1) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_COMP(2,1) 1 ! [D] Divided into (spring compression - CMP_START_FS_COMP)
FS_COMP_COMBINE(2,1) MULTIPLY ! [D] How to combine the two components
FS_COMP_FSTATIC_CONSTANT(2,1) 1 ; - ! [D] Spring force component due to static
                                ! spring force, axle 2, left side

FS_COMP_COEFFICIENT(2,2) 43.781 ! Spring force per unit spring compression (N/mm),
                                ! axle 2, right side
FS_COMP_GAIN(2,2)   1 ! [D] Multiplied with calculated value to get spring force
FS_COMP_OFFSET(2,2) 10 ; N ! Added (after gain) to get spring force
CMP_START_FS_COMP(2,2) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_COMP(2,2) 1 ! [D] Divided into (spring compression - CMP_START_FS_COMP)
FS_COMP_COMBINE(2,2) MULTIPLY ! [D] How to combine the two components
FS_COMP_FSTATIC_CONSTANT(2,2) 1 ; - ! [D] Spring force component due to static
                                ! spring force, axle 2, right side

! FS_EXT: Extension (lower) envelope of suspension spring force (1 side). Spring
! force can be a nonlinear CARPET function of static spring force and spring
! compression or a function of spring compression (CONSTANT, COEFFICIENT, or TABLE)
! combined with a function FS_EXT_FSTATIC of static spring force (CONSTANT,
! COEFFICIENT, or TABLE). Spring force from the calculation can be adjusted with
! FS_EXT_GAIN and FS_EXT_OFFSET. Spring compression used in the calculation can be
! adjusted with CMP_SCALE_FS_EXT and CMP_START_FS_EXT. Static spring force used in
! the calculation can be adjusted with FSTATIC_SCALE_FS_EXT and FSTATIC_START_FS_EXT.
! An inverse version of this function is used internally. This configurable function
! supports 4 datasets; if indices shown below are not used, e.g., (1,2), the current
! values of the indices IAXLE and ISIDE are used to identify the dataset when reading
! data.

FS_EXT_COEFFICIENT(1,1) 39.4 ! Spring force per unit spring compression (N/mm), axle
                             ! 1, left side
FS_EXT_GAIN(1,1)    1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(1,1) -10 ; N ! Added (after gain) to get spring force
CMP_START_FS_EXT(1,1) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_EXT(1,1) 1 ! [D] Divided into (spring compression - CMP_START_FS_EXT)
FS_EXT_COMBINE(1,1) MULTIPLY ! [D] How to combine the two components
FS_EXT_FSTATIC_CONSTANT(1,1) 1 ; - ! [D] Spring force component due to static spring
                               ! force, axle 1, left side

FS_EXT_COEFFICIENT(1,2) 39.4 ! Spring force per unit spring compression (N/mm), axle
                             ! 1, right side
FS_EXT_GAIN(1,2)    1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(1,2) -10 ; N ! Added (after gain) to get spring force
CMP_START_FS_EXT(1,2) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_EXT(1,2) 1 ! [D] Divided into (spring compression - CMP_START_FS_EXT)
FS_EXT_COMBINE(1,2) MULTIPLY ! [D] How to combine the two components
FS_EXT_FSTATIC_CONSTANT(1,2) 1 ; - ! [D] Spring force component due to static spring
                               ! force, axle 1, right side

FS_EXT_COEFFICIENT(2,1) 43.781 ! Spring force per unit spring compression (N/mm),
                               ! axle 2, left side
FS_EXT_GAIN(2,1)    1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(2,1) -10 ; N ! Added (after gain) to get spring force
CMP_START_FS_EXT(2,1) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_EXT(2,1) 1 ! [D] Divided into (spring compression - CMP_START_FS_EXT)
FS_EXT_COMBINE(2,1) MULTIPLY ! [D] How to combine the two components
FS_EXT_FSTATIC_CONSTANT(2,1) 1 ; - ! [D] Spring force component due to static spring
                               ! force, axle 2, left side

FS_EXT_COEFFICIENT(2,2) 43.781 ! Spring force per unit spring compression (N/mm),
                               ! axle 2, right side
FS_EXT_GAIN(2,2)    1 ! [D] Multiplied with calculated value to get spring force
FS_EXT_OFFSET(2,2) -10 ; N ! Added (after gain) to get spring force
CMP_START_FS_EXT(2,2) 0 ; mm ! [D] Subtracted from spring compression
CMP_SCALE_FS_EXT(2,2) 1 ! [D] Divided into (spring compression - CMP_START_FS_EXT)
FS_EXT_COMBINE(2,2) MULTIPLY ! [D] How to combine the two components
FS_EXT_FSTATIC_CONSTANT(2,2) 1 ; - ! [D] Spring force component due to static spring
                               ! force, axle 2, right side

! FX_AERO_SHAPING: Coefficient CFX for for X component of aerodynamic force. CFX is
! a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. CFX from the
! calculation can be adjusted with FX_AERO_SHAPING_GAIN and FX_AERO_SHAPING_OFFSET.
! Aerodynamic slip angle used in the calculation can be adjusted with
! SLIP_SCALE_FX_AERO and SLIP_START_FX_AERO.

FX_AERO_SHAPING_CONSTANT 1.285 ; - ! CFX
FX_AERO_SHAPING_GAIN 1 ! [D] Multiplied with calculated value to get CFX
FX_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get CFX

! FX_AERO_SHAPING_2: Coefficient CFX2 for X component of aerodynamic force. CFX2 can
! be a nonlinear CARPET function of ride height and pitch or a function of pitch
! (CONSTANT, COEFFICIENT, or TABLE) combined with a function FX_AERO_SHAPING_Z of
! ride height (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. CFX2 from the calculation can be adjusted with
! FX_AERO_SHAPING_2_GAIN and FX_AERO_SHAPING_2_OFFSET. Pitch used in the calculation
! can be adjusted with PITCH_SCALE_FX_AERO and PITCH_START_FX_AERO. Ride height used
! in the calculation can be adjusted with Z_SCALE_FX_AERO and Z_START_FX_AERO.

FX_AERO_SHAPING_2_CONSTANT 1 ; - ! [D] CFX2 component due to pitch
FX_AERO_SHAPING_2_GAIN 1 ! [D] Multiplied with calculated value to get CFX2
FX_AERO_SHAPING_2_OFFSET 0 ; - ! [D] Added to get CFX2
FX_AERO_SHAPING_2_COMBINE MULTIPLY ! [D] How to combine the two components
FX_AERO_SHAPING_Z_CONSTANT 1 ; - ! [D] CFX2 component due to ride height

! FY_AERO_SHAPING: Coefficient CFY for for Y component of aerodynamic force. CFY is
! a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. CFY from the
! calculation can be adjusted with FY_AERO_SHAPING_GAIN and FY_AERO_SHAPING_OFFSET.
! Aerodynamic slip angle used in the calculation can be adjusted with
! SLIP_SCALE_FY_AERO and SLIP_START_FY_AERO.

FY_AERO_SHAPING_CONSTANT 0 ; - ! CFY
FY_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get CFY

! FY_AERO_SHAPING_2: Coefficient CFY2 for Y component of aerodynamic force. CFY2 can
! be a nonlinear CARPET function of ride height and pitch or a function of pitch
! (CONSTANT, COEFFICIENT, or TABLE) combined with a function FY_AERO_SHAPING_Z of
! ride height (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. CFY2 from the calculation can be adjusted with
! FY_AERO_SHAPING_2_GAIN and FY_AERO_SHAPING_2_OFFSET. Pitch used in the calculation
! can be adjusted with PITCH_SCALE_FY_AERO and PITCH_START_FY_AERO. Ride height used
! in the calculation can be adjusted with Z_SCALE_FY_AERO and Z_START_FY_AERO.

FY_AERO_SHAPING_2_CONSTANT 1 ; - ! [D] CFY2 component due to pitch
FY_AERO_SHAPING_2_GAIN 1 ! [D] Multiplied with calculated value to get CFY2
FY_AERO_SHAPING_2_OFFSET 0 ; - ! [D] Added to get CFY2
FY_AERO_SHAPING_2_COMBINE MULTIPLY ! [D] How to combine the two components
FY_AERO_SHAPING_Z_CONSTANT 1 ; - ! [D] CFY2 component due to ride height

! FZ_AERO_SHAPING: Coefficient CFZ for for Z component of aerodynamic force. CFZ is
! a function of aerodynamic slip angle (CONSTANT, COEFFICIENT, or TABLE).
! Alternatively, a custom equation can be defined at runtime. CFZ from the
! calculation can be adjusted with FZ_AERO_SHAPING_GAIN and FZ_AERO_SHAPING_OFFSET.
! Aerodynamic slip angle used in the calculation can be adjusted with
! SLIP_SCALE_FZ_AERO and SLIP_START_FZ_AERO.

FZ_AERO_SHAPING_CONSTANT -2.669 ; - ! CFZ
FZ_AERO_SHAPING_GAIN 1 ! [D] Multiplied with calculated value to get CFZ
FZ_AERO_SHAPING_OFFSET 0 ; - ! [D] Added to get CFZ

! FZ_AERO_SHAPING_2: Coefficient CFZ2 for Z component of aerodynamic force. CFZ2 can
! be a nonlinear CARPET function of ride height and pitch or a function of pitch
! (CONSTANT, COEFFICIENT, or TABLE) combined with a function FZ_AERO_SHAPING_Z of
! ride height (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can
! be defined at runtime. CFZ2 from the calculation can be adjusted with
! FZ_AERO_SHAPING_2_GAIN and FZ_AERO_SHAPING_2_OFFSET. Pitch used in the calculation
! can be adjusted with PITCH_SCALE_FZ_AERO and PITCH_START_FZ_AERO. Ride height used
! in the calculation can be adjusted with Z_SCALE_FZ_AERO and Z_START_FZ_AERO.

FZ_AERO_SHAPING_2_CONSTANT 1 ; - ! [D] CFZ2 component due to pitch
FZ_AERO_SHAPING_2_GAIN 1 ! [D] Multiplied with calculated value to get CFZ2
FZ_AERO_SHAPING_2_OFFSET 0 ; - ! [D] Added to get CFZ2
FZ_AERO_SHAPING_2_COMBINE MULTIPLY ! [D] How to combine the two components
FZ_AERO_SHAPING_Z_CONSTANT 1 ; - ! [D] CFZ2 component due to ride height

! F_JNC_STOP: Jounce stop force. Force is a function of suspension travel at jounce
! stop (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be
! defined at runtime. Force from the calculation can be adjusted with F_JNC_STOP_GAIN
! and F_JNC_STOP_OFFSET. Suspension travel at jounce stop used in the calculation can
! be adjusted with CMP_SCALE_F_JNC_STOP and CMP_START_F_JNC_STOP. This configurable
! function supports 4 datasets; if indices shown below are not used, e.g., (1,2), the
! current values of the indices IAXLE and ISIDE are used to identify the dataset when
! reading data.

! Col 1 = suspension travel at jounce stop (mm), col 2 = force (N)
F_JNC_STOP_TABLE(1,1) LINEAR ! axle 1, left side
 0, 0
 43, 0
 44, 100
ENDTABLE
F_JNC_STOP_GAIN(1,1) 1 ! [D] Multiplied with calculated value to get force
F_JNC_STOP_OFFSET(1,1) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_JNC_STOP(1,1) 0 ; mm ! [D] Subtracted from suspension travel at jounce
                            ! stop
CMP_SCALE_F_JNC_STOP(1,1) 1 ! [D] Divided into (suspension travel at jounce stop -
                            ! CMP_START_F_JNC_STOP)

! Col 1 = suspension travel at jounce stop (mm), col 2 = force (N)
F_JNC_STOP_TABLE(1,2) LINEAR ! axle 1, right side
 0, 0
 43, 0
 44, 100
ENDTABLE
F_JNC_STOP_GAIN(1,2) 1 ! [D] Multiplied with calculated value to get force
F_JNC_STOP_OFFSET(1,2) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_JNC_STOP(1,2) 0 ; mm ! [D] Subtracted from suspension travel at jounce
                            ! stop
CMP_SCALE_F_JNC_STOP(1,2) 1 ! [D] Divided into (suspension travel at jounce stop -
                            ! CMP_START_F_JNC_STOP)

! Col 1 = suspension travel at jounce stop (mm), col 2 = force (N)
F_JNC_STOP_TABLE(2,1) LINEAR ! axle 2, left side
 0, 0
 43, 0
 44, 100
ENDTABLE
F_JNC_STOP_GAIN(2,1) 1 ! [D] Multiplied with calculated value to get force
F_JNC_STOP_OFFSET(2,1) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_JNC_STOP(2,1) 0 ; mm ! [D] Subtracted from suspension travel at jounce
                            ! stop
CMP_SCALE_F_JNC_STOP(2,1) 1 ! [D] Divided into (suspension travel at jounce stop -
                            ! CMP_START_F_JNC_STOP)

! Col 1 = suspension travel at jounce stop (mm), col 2 = force (N)
F_JNC_STOP_TABLE(2,2) LINEAR ! axle 2, right side
 0, 0
 43, 0
 44, 100
ENDTABLE
F_JNC_STOP_GAIN(2,2) 1 ! [D] Multiplied with calculated value to get force
F_JNC_STOP_OFFSET(2,2) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_JNC_STOP(2,2) 0 ; mm ! [D] Subtracted from suspension travel at jounce
                            ! stop
CMP_SCALE_F_JNC_STOP(2,2) 1 ! [D] Divided into (suspension travel at jounce stop -
                            ! CMP_START_F_JNC_STOP)

! F_REB_STOP: Rebound stop force. Force is a function of suspension travel at
! rebound stop (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation
! can be defined at runtime. Force from the calculation can be adjusted with
! F_REB_STOP_GAIN and F_REB_STOP_OFFSET. Suspension travel at rebound stop used in
! the calculation can be adjusted with CMP_SCALE_F_REB_STOP and CMP_START_F_REB_STOP.
! This configurable function supports 4 datasets; if indices shown below are not
! used, e.g., (1,2), the current values of the indices IAXLE and ISIDE are used to
! identify the dataset when reading data.

! Col 1 = suspension travel at rebound stop (mm), col 2 = force (N)
F_REB_STOP_TABLE(1,1) LINEAR ! axle 1, left side
 -13, -1000
 -12, 0
 0, 0
ENDTABLE
F_REB_STOP_GAIN(1,1) 1 ! [D] Multiplied with calculated value to get force
F_REB_STOP_OFFSET(1,1) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_REB_STOP(1,1) 0 ; mm ! [D] Subtracted from suspension travel at rebound
                            ! stop
CMP_SCALE_F_REB_STOP(1,1) 1 ! [D] Divided into (suspension travel at rebound stop -
                            ! CMP_START_F_REB_STOP)

! Col 1 = suspension travel at rebound stop (mm), col 2 = force (N)
F_REB_STOP_TABLE(1,2) LINEAR ! axle 1, right side
 -13, -1000
 -12, 0
 0, 0
ENDTABLE
F_REB_STOP_GAIN(1,2) 1 ! [D] Multiplied with calculated value to get force
F_REB_STOP_OFFSET(1,2) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_REB_STOP(1,2) 0 ; mm ! [D] Subtracted from suspension travel at rebound
                            ! stop
CMP_SCALE_F_REB_STOP(1,2) 1 ! [D] Divided into (suspension travel at rebound stop -
                            ! CMP_START_F_REB_STOP)

! Col 1 = suspension travel at rebound stop (mm), col 2 = force (N)
F_REB_STOP_TABLE(2,1) LINEAR ! axle 2, left side
 -13, -1000
 -12, 0
 0, 0
ENDTABLE
F_REB_STOP_GAIN(2,1) 1 ! [D] Multiplied with calculated value to get force
F_REB_STOP_OFFSET(2,1) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_REB_STOP(2,1) 0 ; mm ! [D] Subtracted from suspension travel at rebound
                            ! stop
CMP_SCALE_F_REB_STOP(2,1) 1 ! [D] Divided into (suspension travel at rebound stop -
                            ! CMP_START_F_REB_STOP)

! Col 1 = suspension travel at rebound stop (mm), col 2 = force (N)
F_REB_STOP_TABLE(2,2) LINEAR ! axle 2, right side
 -13, -1000
 -12, 0
 0, 0
ENDTABLE
F_REB_STOP_GAIN(2,2) 1 ! [D] Multiplied with calculated value to get force
F_REB_STOP_OFFSET(2,2) 0 ; N ! [D] Added (after gain) to get force
CMP_START_F_REB_STOP(2,2) 0 ; mm ! [D] Subtracted from suspension travel at rebound
                            ! stop
CMP_SCALE_F_REB_STOP(2,2) 1 ! [D] Divided into (suspension travel at rebound stop -
                            ! CMP_START_F_REB_STOP)

! ISHAFT_KIN: Intermediate shaft kinematics. Shaft output angle is a function of
! intermediate shaft input angle (CONSTANT, COEFFICIENT, or TABLE). Shaft output
! angle from the calculation can be adjusted with ISHAFT_KIN_GAIN and
! ISHAFT_KIN_OFFSET. An inverse version of this function is used internally. The
! derivative of this function is used internally.

ISHAFT_KIN_COEFFICIENT 1 ! [D] Shaft output angle per unit intermediate shaft input
                         ! angle (deg/deg)
ISHAFT_KIN_GAIN     1 ! [D] Multiplied with calculated value to get Shaft output
                      ! angle
ISHAFT_KIN_OFFSET   0 ; deg ! [D] Added (after gain) to get Shaft output angle

! MMOTOR_MAX: Motor maximum torque. Motor full torque is a function of motor speed
! (CONSTANT, COEFFICIENT, or TABLE). Alternatively, a custom equation can be defined
! at runtime. Motor full torque from the calculation can be adjusted with
! MMOTOR_MAX_GAIN and MMOTOR_MAX_OFFSET. Motor speed used in the calculation can be
! adjusted with SPIN_SCALE_M_MOTOR_MAX and SPIN_START_M_MOTOR_MAX. This configurable
! function supports 6 datasets; if indices shown below are not used, e.g., (1,2), the
! current values of the indices IDIFF and ISIDE are used to identify the dataset when
! reading data.

! Col 1 = motor speed (rpm), col 2 = Motor full torque (N-m)
MMOTOR_MAX_TABLE(2,1) SPLINE_FLAT ! spline interpolation, flat-line extrapolation
